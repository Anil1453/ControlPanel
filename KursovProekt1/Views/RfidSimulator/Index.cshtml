@{
    ViewData["Title"] = "RFID Симулатор";
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">RFID Симулатор</div>
        <div class="cp-page-subtitle">Тест на системата без реално устройство</div>
    </div>
    <span class="cp-rfid-online">
        <span class="cp-rfid-dot"></span>
        Системата е активна
    </span>
</div>

<div class="cp-grid-2">

    <div class="cp-card">
        <div class="cp-card-header">
            <span class="cp-card-title">Симулирай четец</span>
        </div>
        <div class="cp-card-body">
            <p class="cp-rfid-desc">
                Изберете потребител и зона, за да симулирате приближаване на RFID карта.
            </p>

            <div class="cp-form-group cp-rfid-group-mb">
                <label class="cp-form-label">Потребител</label>
                <select id="selUser" class="cp-form-control">
                    <option value="">— изберете потребител —</option>
                    @foreach (var u in ViewBag.Users)
                    {
                        <option value="@u.Email">@(u.FullName ?? u.Email)</option>
                    }
                </select>
            </div>

            <div class="cp-form-group cp-rfid-group-mb-lg">
                <label class="cp-form-label">Зона</label>
                <select id="selRoom" class="cp-form-control">
                    <option value="">— изберете зона —</option>
                    @foreach (var r in ViewBag.Rooms)
                    {
                        <option value="@r.Id">@r.RoomName (@r.RoomCode)</option>
                    }
                </select>
            </div>

            <button id="btnSimulate" class="cp-btn cp-btn-primary cp-rfid-submit" onclick="simulate()">
                <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0 1 12 2v5h4a1 1 0 0 1 .82 1.573l-7 10A1 1 0 0 1 8 18v-5H4a1 1 0 0 1-.82-1.573l7-10a1 1 0 0 1 1.12-.38z" clip-rule="evenodd" /></svg>
                Симулирай достъп
            </button>

            <div id="result" class="cp-rfid-result"></div>
        </div>
    </div>

    <div class="cp-card">
        <div class="cp-card-header">
            <span class="cp-card-title">Как работи?</span>
        </div>
        <div class="cp-card-body">
            <div class="cp-rfid-steps">
                <div class="cp-rfid-step">
                    <div class="cp-rfid-step-num cp-rfid-step-num-blue">1</div>
                    <div><strong>Изберете потребител и зона</strong><br>Симулира приближаване на RFID карта до четец на избраната зона.</div>
                </div>
                <div class="cp-rfid-step">
                    <div class="cp-rfid-step-num cp-rfid-step-num-blue">2</div>
                    <div><strong>Системата проверява</strong><br>Дали потребителят има одобрена заявка за тази зона.</div>
                </div>
                <div class="cp-rfid-step">
                    <div class="cp-rfid-step-num cp-rfid-step-num-green">✓</div>
                    <div><strong class="cp-check-yes-text">Одобрен достъп</strong><br>Вратата се отваря → записва се в логовете.</div>
                </div>
                <div class="cp-rfid-step">
                    <div class="cp-rfid-step-num cp-rfid-step-num-red">✗</div>
                    <div><strong class="cp-check-no-text">Отказан достъп</strong><br>Вратата остава заключена → записва се в логовете.</div>
                </div>
                <div class="cp-rfid-note">
                    Реалното устройство изпраща GET заявка към:<br>
                    <code class="cp-rfid-code">/api/rfid/check?userEmail=...&amp;roomId=...</code>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    async function simulate() {
        var email  = document.getElementById('selUser').value;
        var roomId = document.getElementById('selRoom').value;
        var result = document.getElementById('result');

        result.style.display = 'block';

        if (!email || !roomId) {
            result.innerHTML = '<div style="padding:14px; background:#fef9c3; border:1px solid #fde047; border-radius:8px; font-size:13px; color:#854d0e">⚠️ Моля, изберете потребител и зона!</div>';
            return;
        }

        result.innerHTML = '<div class="cp-empty"><div class="cp-empty-sub">Проверява се...</div></div>';

        try {
            var resp = await fetch('/api/rfid/check?userEmail=' + encodeURIComponent(email) + '&roomId=' + roomId);
            var data = await resp.json();

            if (data.status === 'Approved') {
                result.innerHTML = `
                    <div style="padding:16px; background:#f0fdf4; border:2px solid #16a34a; border-radius:10px; text-align:center">
                        <div style="font-size:32px; margin-bottom:8px">✅</div>
                        <div style="font-weight:700; color:#16a34a; font-size:16px; margin-bottom:4px">ДОСТЪПЪТ Е РАЗРЕШЕН</div>
                        <div style="font-size:13px; color:#166534">Потребителят има одобрена заявка. Записано в логовете.</div>
                    </div>`;
            } else {
                result.innerHTML = `
                    <div style="padding:16px; background:#fef2f2; border:2px solid #dc2626; border-radius:10px; text-align:center">
                        <div style="font-size:32px; margin-bottom:8px">🚫</div>
                        <div style="font-weight:700; color:#dc2626; font-size:16px; margin-bottom:4px">ДОСТЪПЪТ Е ОТКАЗАН</div>
                        <div style="font-size:13px; color:#991b1b">Няма одобрена заявка или потребителят е деактивиран.</div>
                    </div>`;
            }
        } catch (e) {
            result.innerHTML = '<div style="padding:14px; background:#fef2f2; border:1px solid #fca5a5; border-radius:8px; font-size:13px; color:#991b1b">❌ Грешка при свързване с API.</div>';
        }
    }
</script>

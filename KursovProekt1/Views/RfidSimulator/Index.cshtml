@{
    ViewData["Title"] = "RFID Симулатор";
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">RFID Симулатор</div>
        <div class="cp-page-subtitle">Симулира четец на RFID карта за тестване на системата</div>
    </div>
    <span style="display:flex;align-items:center;gap:6px;font-size:12px;color:#16a34a;background:#f0fdf4;border:1px solid #bbf7d0;padding:5px 12px;border-radius:20px">
        <span style="width:7px;height:7px;background:#16a34a;border-radius:50%;animation:pulse 2s infinite;display:inline-block"></span>
        Системата работи
    </span>
</div>

<div class="cp-grid-2">
    <div class="cp-card">
        <div class="cp-card-header">
            <span class="cp-card-title">Симулирай RFID четец</span>
        </div>
        <div class="cp-card-body">
            <p style="font-size:13px;color:var(--text-secondary);margin-bottom:20px">
                Изберете потребител и зона. Системата ще провери дали потребителят има одобрен достъп и ще запише резултата в логовете.
            </p>

            <div class="cp-form-group" style="margin-bottom:16px">
                <label class="cp-label">Потребител (имейл)</label>
                <select id="userSelect" class="cp-form-control">
                    <option value="">— Изберете потребител —</option>
                    @if (ViewBag.Users != null)
                    {
                        foreach (var user in ViewBag.Users)
                        {
                            <option value="@user.Email">@user.Email @(user.FullName != null ? $"({user.FullName})" : "")</option>
                        }
                    }
                </select>
            </div>

            <div class="cp-form-group" style="margin-bottom:24px">
                <label class="cp-label">Зона</label>
                <select id="roomSelect" class="cp-form-control">
                    <option value="">— Изберете зона —</option>
                    @if (ViewBag.Rooms != null)
                    {
                        foreach (var room in ViewBag.Rooms)
                        {
                            <option value="@room.Id">@room.RoomName (@room.RoomCode)</option>
                        }
                    }
                </select>
            </div>

            <button id="btnSimulate" class="cp-btn cp-btn-primary" style="width:100%;justify-content:center" onclick="simulate()">
                Симулирай четец
            </button>

            <div id="result" style="margin-top:20px;display:none"></div>
        </div>
    </div>

    <div class="cp-card">
        <div class="cp-card-header">
            <span class="cp-card-title">Как работи?</span>
        </div>
        <div class="cp-card-body">
            <div style="display:flex;flex-direction:column;gap:16px;font-size:13px;color:var(--text-secondary)">
                <div style="display:flex;gap:12px">
                    <div style="width:28px;height:28px;border-radius:50%;background:#dbeafe;color:#1d4ed8;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:12px">1</div>
                    <div><strong style="color:var(--text)">Изберете потребител и зона</strong><br>Симулира приближаване на RFID карта до четец на избраната зона.</div>
                </div>
                <div style="display:flex;gap:12px">
                    <div style="width:28px;height:28px;border-radius:50%;background:#dbeafe;color:#1d4ed8;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:12px">2</div>
                    <div><strong style="color:var(--text)">Системата проверява</strong><br>Дали потребителят има одобрена заявка за тази зона.</div>
                </div>
                <div style="display:flex;gap:12px">
                    <div style="width:28px;height:28px;border-radius:50%;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:12px">✓</div>
                    <div><strong style="color:#16a34a">Одобрен достъп</strong><br>Вратата се отваря → записва се в логовете.</div>
                </div>
                <div style="display:flex;gap:12px">
                    <div style="width:28px;height:28px;border-radius:50%;background:#fee2e2;color:#dc2626;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:12px">✗</div>
                    <div><strong style="color:#dc2626">Отказан достъп</strong><br>Вратата остава заключена → записва се в логовете.</div>
                </div>
                <div style="padding:12px;background:#f8fafc;border-radius:8px;border:1px solid var(--border);font-size:12px">
                    <strong>API Endpoint:</strong><br>
                    <code style="font-size:11px;color:#6366f1">/api/rfid/check?userEmail=...&amp;roomId=...</code>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }
</style>

<script>
    async function simulate() {
        var email  = document.getElementById('userSelect').value;
        var roomId = document.getElementById('roomSelect').value;
        var result = document.getElementById('result');
        var btn    = document.getElementById('btnSimulate');

        if (!email || !roomId) {
            result.style.display = 'block';
            result.innerHTML = '<div style="padding:14px;background:#fef9c3;border:1px solid #fde047;border-radius:8px;font-size:13px;color:#854d0e">⚠️ Моля, изберете потребител и зона!</div>';
            return;
        }

        btn.disabled = true;
        btn.textContent = 'Проверява се...';

        try {
            var response = await fetch('/api/rfid/check?userEmail=' + encodeURIComponent(email) + '&roomId=' + roomId);
            var data     = await response.json();

            result.style.display = 'block';

            if (data.status === 'Approved') {
                result.innerHTML = `
                    <div style="padding:16px;background:#f0fdf4;border:2px solid #16a34a;border-radius:10px;text-align:center">
                        <div style="font-size:32px;margin-bottom:8px">✅</div>
                        <div style="font-weight:700;color:#16a34a;font-size:16px;margin-bottom:4px">ДОСТЪПЪТ Е РАЗРЕШЕН</div>
                        <div style="font-size:13px;color:#166534">Потребителят има одобрена заявка. Записано в логовете.</div>
                    </div>`;
            } else {
                result.innerHTML = `
                    <div style="padding:16px;background:#fef2f2;border:2px solid #dc2626;border-radius:10px;text-align:center">
                        <div style="font-size:32px;margin-bottom:8px">🚫</div>
                        <div style="font-weight:700;color:#dc2626;font-size:16px;margin-bottom:4px">ДОСТЪПЪТ Е ОТКАЗАН</div>
                        <div style="font-size:13px;color:#991b1b">Няма одобрена заявка или потребителят е деактивиран.</div>
                    </div>`;
            }
        } catch (e) {
            result.innerHTML = '<div style="padding:14px;background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;font-size:13px;color:#991b1b">❌ Грешка при свързване с API.</div>';
        } finally {
            btn.disabled = false;
            btn.textContent = 'Симулирай четец';
        }
    }
</script>
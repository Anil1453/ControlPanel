@model ControlPanel.Models.Room
@{
    ViewData["Title"] = "Изтриване на зона";
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">Изтриване на зона</div>
        <div class="cp-page-subtitle">Тази операция е необратима</div>
    </div>
    <a href="/Room/Index" class="cp-btn cp-btn-ghost">← Назад</a>
</div>

<div class="cp-card cp-card-xs">
    <div class="cp-card-header cp-delete-header">
        <span class="cp-card-title cp-delete-title">Потвърдете изтриването</span>
    </div>
    <div class="cp-card-body">
        <div class="cp-delete-info">
            <div class="cp-delete-row">
                <span class="cp-delete-key">Стая</span>
                <span class="cp-detail-value">@Model.RoomName</span>
            </div>
            <div class="cp-delete-row">
                <span class="cp-delete-key">Код</span>
                <span class="cp-delete-mono">@Model.RoomCode</span>
            </div>
            <div class="cp-delete-row">
                <span class="cp-delete-key">Ниво на достъп</span>
                <span class="cp-badge cp-level-@Model.AccessLevel">Ниво @Model.AccessLevel</span>
            </div>
        </div>

        <p class="cp-delete-warning">
            Изтриването ще премахне зоната заедно с всички свързани логове и заявки. Сигурни ли сте?
        </p>

        <div class="cp-flex-gap8">
            <form method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="cp-btn cp-btn-danger">Да, изтрий</button>
            </form>
            <a href="/Room/Index" class="cp-btn cp-btn-ghost">Отказ</a>
        </div>
    </div>
</div>

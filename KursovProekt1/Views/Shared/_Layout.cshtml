<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ControlPanel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ControlPanel.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-4 py-2">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold fs-5 text-primary" asp-area="" asp-controller="Home" asp-action="Index">🛡️ ControlPanel</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 fs-6">
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Home" asp-action="Index">🏠 Начало</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Room" asp-action="Index">🚪 Стаи</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="AccessLog" asp-action="Index">📋 Логове</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="AccessRequest" asp-action="Index">📨 Заявки</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="User" asp-action="Index">👥 Потребители</a></li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container bg-white p-4 p-md-5 rounded-4 shadow-sm border border-light">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center py-2 mt-3 ">
        <div class="container" style="font-size: 0.95rem;">
            &copy; 2026 - Системен Панел - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="fw-bold text-decoration-none">Поверителност</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@* Тази страница няма типизиран модел — данните идват от ViewBag *@
@{
    ViewData["Title"] = "Нова заявка";
}

@* ===== ЗАГЛАВНА ЛЕНТА ===== *@
<div class="cp-page-header">
    <div>
        <div class="cp-page-title">Нова заявка за достъп</div>
        <div class="cp-page-subtitle">Попълнете формата, за да поискате достъп до стая</div>
    </div>
    <a asp-action="Index" class="cp-btn cp-btn-ghost">← Назад</a>
</div>

@* ===== ФОРМА ===== *@
<div class="cp-card cp-card-xs">
    <div class="cp-card-header">
        <span class="cp-card-title">Данни за заявката</span>
    </div>
    <div class="cp-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @* Избор на стая *@
            <div class="cp-form-group">
                <label class="cp-form-label">Стая <span class="req">*</span></label>
                <select name="roomId" class="cp-form-control">
                    @foreach (var room in ViewBag.Rooms)
                    {
                        <option value="@room.Id">@room.RoomName</option>
                    }
                </select>
            </div>

            @* Причина за заявката *@
            <div class="cp-form-group">
                <label class="cp-form-label">Причина <span class="req">*</span></label>
                <textarea name="reason" class="cp-form-control" rows="3" required placeholder="Опишете накратко причината..."></textarea>
            </div>

            @* Бутони *@
            <div class="cp-form-actions">
                <button type="submit" class="cp-btn cp-btn-primary">Изпрати заявката</button>
                <a asp-action="Index" class="cp-btn cp-btn-ghost">Отказ</a>
            </div>

        </form>
    </div>
</div>
@* Моделът е списък от заявки за достъп *@
@model IEnumerable<ControlPanel.Models.AccessRequest>

@{
    ViewData["Title"] = "Заявки";
}

@* ===== ЗАГЛАВНА ЛЕНТА ===== *@
<div class="cp-page-header">
    <div>
        <div class="cp-page-title">Заявки за достъп</div>
        <div class="cp-page-subtitle">
            @* Подзаглавието се мени според ролята *@
            @if (User.IsInRole("Admin") || User.IsInRole("Мениджър") || User.IsInRole("Служител"))
            {
                <text>Преглед и управление на всички заявки</text>
            }
            else
            {

                <text>Вашите заявки за достъп до стаи</text>
            }
        </div>
    </div>
    <a asp-action="Create" class="cp-btn cp-btn-primary">
        <svg fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 3a1 1 0 0 1 1 1v5h5a1 1 0 1 1 0 2h-5v5a1 1 0 1 1-2 0v-5H4a1 1 0 1 1 0-2h5V4a1 1 0 0 1 1-1z" clip-rule="evenodd" />
        </svg>
        Нова заявка
    </a>
</div>

@* ===== ФИЛТЪР — само за Admin, Мениджър, Служител ===== *@
@if (User.IsInRole("Admin") || User.IsInRole("Мениджър") || User.IsInRole("Служител"))
{
    <div class="cp-filter-bar">
        <form method="get" class="cp-search-form">

            @* Търсене по имейл *@
            <input type="text"
                   name="search"
                   value="@ViewBag.SearchQuery"
                   placeholder="Търси по имейл на потребител..."
                   class="cp-form-control"
                   class="cp-search-input cp-form-control" />

            <button type="submit" class="cp-btn cp-btn-ghost cp-search-btn">
                Търси
            </button>

            @* Бутон "Изчисти" — само ако има активно търсене *@
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
            {
                <a href="/AccessRequest/Index" class="cp-btn cp-btn-ghost cp-search-clear">
                    × Изчисти
                </a>
            }

            <span class="cp-record-count">@Model.Count() заявки</span>
        </form>
    </div>
}

@* ===== ТАБЛИЦА СЪС ЗАЯВКИ ===== *@
<div class="cp-card">
    <div class="cp-card-body-flush">
        @if (!Model.Any())
        {
            @* Празно състояние *@
            <div class="cp-empty">
                <div class="cp-empty-icon">
                    <svg fill="currentColor" viewBox="0 0 20 20">
                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0 0 16 4H4a2 2 0 0 0-1.997 1.884z" />
                        <path d="m18 8.118-8 4-8-4V14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8.118z" />
                    </svg>
                </div>
                <div class="cp-empty-title">Няма заявки</div>
                <div class="cp-empty-sub">Когато бъде подадена заявка за достъп, тя ще се появи тук.</div>
            </div>
        }
        else
        {
            <table class="cp-table">
                <thead>
                    <tr>
                        <th>Потребител</th>
                        <th>Стая</th>
                        <th>Причина</th>
                        <th>Дата</th>
                        <th>Статус</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("Мениджър") || User.IsInRole("Служител"))
                        {
                            <th class="cp-th-right">Действия</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model)
                    {
                        <tr>

                            @* Потребител с аватар *@
                            <td>
                                <div class="cp-flex-gap8">
                                    <div class="cp-avatar">@(req.User?.Email?.Substring(0, 2).ToUpper() ?? "??")</div>
                                    <span class="cp-user-email">@(req.User?.Email ?? "—")</span>
                                </div>
                            </td>

                            <td class="cp-req-room">@(req.Room?.RoomName ?? "—")</td>
                            <td class="cp-req-reason">@req.Reason</td>
                            <td class="cp-req-date">@req.RequestDate.ToString("dd.MM.yyyy HH:mm")</td>

                            @* Статус badge *@
                            <td>
                                @if (req.Status == "Approved")
                                {
                                    <span class="cp-badge cp-badge-green"><span class="dot"></span> Одобрена</span>
                                }
                                else if (req.Status == "Denied")
                                {

                                    <span class="cp-badge cp-badge-red"><span class="dot"></span> Отказана</span>
                                }
                                else
                                {

                                    <span class="cp-badge cp-badge-amber"><span class="dot"></span> В изчакване</span>
                                }
                            </td>

                            @* Одобри / Откажи — само за Admin, Мениджър, Служител *@
                            @if (User.IsInRole("Admin") || User.IsInRole("Мениджър") || User.IsInRole("Служител"))
                            {
                                <td class="cp-td-right">
                                    @if (req.Status == "Pending")
                                    {
                                        <div class="cp-flex-gap6">

                                            @* Бутон Одобри *@
                                            <form method="post" asp-action="Approve" asp-route-id="@req.Id" class="cp-form-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="cp-btn-icon success" title="Одобри">
                                                    <svg fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 0 1 0 1.414l-8 8a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 1.414-1.414L8 12.586l7.293-7.293a1 1 0 0 1 1.414 0z" clip-rule="evenodd" />
                                                    </svg>
                                                </button>
                                            </form>

                                            @* Бутон Откажи *@
                                            <form method="post" asp-action="Deny" asp-route-id="@req.Id" class="cp-form-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="cp-btn-icon danger" title="Откажи">
                                                    <svg fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 0 1 1.414 0L10 8.586l4.293-4.293a1 1 0 1 1 1.414 1.414L11.414 10l4.293 4.293a1 1 0 0 1-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 0 1-1.414-1.414L8.586 10 4.293 5.707a1 1 0 0 1 0-1.414z" clip-rule="evenodd" />
                                                    </svg>
                                                </button>
                                            </form>

                                        </div>
                                    }
                                    else
                                    {
                                        @* Ако вече е обработена — показваме отговора на администратора *@
                                        <span class="cp-req-admin-note">@req.AdminResponse</span>
                                    }
                                </td>
                            }

                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
@model IEnumerable<ControlPanel.Models.AccessRequest>
@{
    ViewData["Title"] = "Заявки";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="fw-bold text-dark mb-0">📨 Заявки за достъп</h2>
        <p class="text-muted mb-0">Управление на исканията за достъп до стаите.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary bg-gradient shadow-sm rounded-pill px-4 fw-bold">
        ➕ Нова заявка
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-4">✅ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm rounded-4">❌ @TempData["Error"]</div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">

        @* EĞER HİÇ İSTEK YOKSA BU KISIM GÖRÜNECEK (Empty State) *@
        @if (!Model.Any())
        {
            <div class="text-center p-5 my-4">
                <h1 class="display-3 text-muted mb-3">🤷‍♂️</h1>
                <h4 class="fw-bold text-dark">Все още няма заявки.</h4>
                <p class="text-muted">Когато някой поиска достъп, ще се появи тук.</p>
            </div>
        }
        else
        {
            @* EĞER İSTEK VARSA ŞIK TABLO GÖRÜNECEK *@
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary">Потребител</th>
                        <th class="py-3 text-secondary">Стая</th>
                        <th class="py-3 text-secondary">Причина</th>
                        <th class="py-3 text-secondary">Дата</th>
                        <th class="py-3 text-secondary">Статус</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end px-4 py-3 text-secondary">Действия</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold text-dark">@req.User?.Email</td>
                            <td class="text-primary fw-semibold">@req.Room?.RoomName</td>
                            <td class="text-muted">@req.Reason</td>
                            <td>@req.RequestDate.ToString("dd.MM.yyyy HH:mm")</td>

                            @* 🌟 PREMIUM RENKLİ ROZETLER (BADGE) KISMI *@
                            <td>
                                @if (req.Status == "Approved")
                                {
                                    <span class="badge bg-success bg-gradient rounded-pill px-3 py-2">✅ Одобрена</span>
                                }
                                else if (req.Status == "Denied")
                                {
                                    <span class="badge bg-danger bg-gradient rounded-pill px-3 py-2">❌ Отказана</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning bg-gradient text-dark rounded-pill px-3 py-2">⏳ Изчаква</span>
                                }
                            </td>

                            @* SADECE ADMİNİN GÖRECEĞİ BUTONLAR *@
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end px-4">
                                    @if (req.Status == "Pending")
                                    {
                                        <form method="post" asp-action="Approve" asp-route-id="@req.Id" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success btn-sm rounded-pill px-3 fw-bold shadow-sm">Одобри</button>
                                        </form>
                                        <form method="post" asp-action="Deny" asp-route-id="@req.Id" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3 fw-bold shadow-sm ms-1">Откажи</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fw-semibold">@req.AdminResponse</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }

    </div>
</div>
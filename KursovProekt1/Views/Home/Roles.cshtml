@{
    ViewData["Title"] = "Роли и права";
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">Роли и права за достъп</div>
        <div class="cp-page-subtitle">Всяка роля определя какво може да прави потребителят</div>
    </div>
</div>

<div class="cp-roles-grid">

    @* Потребител *@
    <div class="cp-card">
        <div class="cp-card-header">
            <div class="cp-flex-gap10">
                <div class="cp-role-icon-wrap cp-role-icon-wrap-gray">
                    <svg class="cp-role-svg-gray" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-7 9a7 7 0 1 1 14 0H3z" clip-rule="evenodd" /></svg>
                </div>
                <div>
                    <div class="cp-role-name">Потребител</div>
                    <div class="cp-role-sub">Базова роля</div>
                </div>
            </div>
        </div>
        <div class="cp-card-body cp-role-body-col">
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Вижда списъка на зони</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Изпраща заявки за достъп</div>
            <div class="cp-role-check-row"><span class="cp-check-no">✕</span> Не може да одобрява заявки</div>
            <div class="cp-role-check-row"><span class="cp-check-no">✕</span> Не управлява зони</div>
        </div>
    </div>

    @* Служител *@
    <div class="cp-card">
        <div class="cp-card-header">
            <div class="cp-flex-gap10">
                <div class="cp-role-icon-wrap cp-role-icon-wrap-blue">
                    <svg class="cp-role-svg-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 6V5a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1h2a2 2 0 0 1 2 2v3.57A22.952 22.952 0 0 1 10 13a22.95 22.95 0 0 1-8-1.43V8a2 2 0 0 1 2-2h2zm2-1a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1H8V5zm1 5a1 1 0 0 1 1-1h.01a1 1 0 1 1 0 2H10a1 1 0 0 1-1-1z" clip-rule="evenodd" /><path d="M2 13.692V16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2.308A24.974 24.974 0 0 1 10 15c-2.796 0-5.487-.46-8-1.308z" /></svg>
                </div>
                <div>
                    <div class="cp-role-name">Служител</div>
                    <div class="cp-role-sub">Може да одобрява заявки</div>
                </div>
            </div>
        </div>
        <div class="cp-card-body cp-role-body-col">
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Всичко от Потребител</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Вижда всички заявки</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Одобрява / отказва заявки</div>
            <div class="cp-role-check-row"><span class="cp-check-no">✕</span> Не управлява зони</div>
        </div>
    </div>

    @* Мениджър *@
    <div class="cp-card">
        <div class="cp-card-header">
            <div class="cp-flex-gap10">
                <div class="cp-role-icon-wrap cp-role-icon-wrap-amber">
                    <svg class="cp-role-svg-amber" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM18 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM14 15a4 4 0 0 0-8 0v3h8v-3zM6 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM16 18v-3a5.972 5.972 0 0 0-.75-2.906A3.005 3.005 0 0 1 19 15v3h-3zM4.75 12.094A5.973 5.973 0 0 0 4 15v3H1v-3a3 3 0 0 1 3.75-2.906z" /></svg>
                </div>
                <div>
                    <div class="cp-role-name">Мениджър</div>
                    <div class="cp-role-sub">Управлява зони и потребители</div>
                </div>
            </div>
        </div>
        <div class="cp-card-body cp-role-body-col">
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Всичко от Служител</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Добавя / редактира зони</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Управлява потребители</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> RFID симулатор</div>
        </div>
    </div>

    @* Администратор *@
    <div class="cp-card cp-card-blue-border">
        <div class="cp-card-header cp-card-header-blue">
            <div class="cp-flex-gap10">
                <div class="cp-role-icon-wrap cp-role-icon-wrap-solid">
                    <svg class="cp-role-svg-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0 0 10 1.944 11.954 11.954 0 0 0 17.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 0 0-1.414-1.414L9 10.586 7.707 9.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4z" clip-rule="evenodd" /></svg>
                </div>
                <div>
                    <div class="cp-role-name-blue">Администратор</div>
                    <div class="cp-role-sub-blue">Пълен достъп до системата</div>
                </div>
            </div>
        </div>
        <div class="cp-card-body cp-role-body-col">
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Всичко от Мениджър</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Изтрива зони</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Деактивира потребители</div>
            <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Пълен достъп до логове</div>
        </div>
    </div>

</div>

<div class="cp-card cp-card-xs">
    <div class="cp-card-header">
        <span class="cp-card-title">Легенда</span>
    </div>
    <div class="cp-card-body cp-role-check-list">
        <div class="cp-role-check-row"><span class="cp-check-yes">✓</span> Позволено действие</div>
        <div class="cp-role-check-row"><span class="cp-check-no">✕</span> Забранено действие</div>
    </div>
</div>
